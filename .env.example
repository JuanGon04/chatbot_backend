# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────

# Port the NestJS application will listen on
PORT=3000

# Current runtime environment. Use "dev" for local development
# and "prod" for production deployments.
ENVIRONMENT="dev"

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────

# Allowed origins when ENVIRONMENT=prod.
# "*" allows all origins (not recommended for production —
# restrict this to your actual frontend/client domain(s)).
ORIGINS_PROD="*"

# Allowed origins when ENVIRONMENT=dev.
# "*" is fine for local development.
ORIGINS_DEV="*"

# ──────────────────────────────────────────────
# OpenAI — Chat Completions API
# ──────────────────────────────────────────────

# Your OpenAI secret key.
# Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"

# Chat model used for tool calling (function calling with
# searchProducts and convertCurrencies). gpt-4o-mini is the
# recommended low-cost option for this use case.
MODEL="gpt-4o-mini"

# Sampling temperature for chat completions.
# Lower values (closer to 0) make responses more deterministic
# and consistent. Higher values (closer to 1) introduce more
# variability and creativity in the model's wording.
TEMPERATURE=0.3

# Maximum number of tool-calling rounds allowed per request.
# Prevents runaway loops (and uncontrolled API costs) if the
# model were to keep requesting tools without ever reaching a
# final answer.
MAX_TOOL_ROUNDS=5

# ──────────────────────────────────────────────
# OpenAI — Embeddings API (used by ProductsService)
# ──────────────────────────────────────────────

# Embedding model used to generate vector representations of
# the product catalog and search queries, enabling semantic
# (meaning-based) product search instead of plain keyword matching.
EMBEDDING_MODEL="text-embedding-3-small"

# Maximum number of products returned by searchProducts,
# ranked by similarity to the user's query.
TOP_N_RESULTS=2

# ──────────────────────────────────────────────
# Open Exchange Rates API (used by CurrencyService)
# ──────────────────────────────────────────────

# Your Open Exchange Rates App ID.
# Get a free one (no credit card required) at
# https://openexchangerates.org/signup
OPEN_EXCHANGE_RATES_APP_ID="YOUR_OPEN_EXCHANGE_RATES_APP_ID_HERE"

# Base URL for fetching the latest exchange rates.
# Note: the free plan only returns rates relative to USD as the
# base currency — conversions between two non-USD currencies are
# computed locally by routing through USD.
OPEN_EXCHANGE_RATES_BASE_URL='https://openexchangerates.org/api/latest.json'

# How long (in milliseconds) to cache exchange rates before
# fetching new ones. Matches the free plan's hourly update
# frequency and helps stay within its 1,000 requests/month limit.
RATES_CACHE_TTL_MS=3600000